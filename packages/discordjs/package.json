{
  "name": "@mochi-analytics/discordjs",
  "version": "1.1.0",
  "description": "discord.js adapter for Mochi — auto-instruments commands, guild joins/leaves, and health snapshots",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mochi-analytics/mochi-js.git",
    "directory": "packages/discordjs"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mochi-analytics/core": "^1.0.0"
  },
  "peerDependencies": {
    "discord.js": "^14.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "discord.js": "^14.19.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0"
  },
  "keywords": [
    "discord",
    "discord.js",
    "bot",
    "analytics",
    "mochi"
  ]
}
